import pandas as pd
from sklearn.linear_model import LinearRegression
data={
    'mobile_useage_hours':[1,2,3,4,5,6],
    'battery_charge':[10,25,40,60,65,85]
}
df =pd.DataFrame(data)
X=df[['mobile_useage_hours']]
y=df['battery_charge']
model=LinearRegression()
model.fit(X,y)
pred=model.predict([[7]])
print("prediction: ",pred[0],"%")
